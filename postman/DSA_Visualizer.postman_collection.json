    {
      "name": "Save Code",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Binary Search Demo\",\n  \"code\": \"function binarySearch(arr, target) { return -1; }\",\n  \"language\": \"javascript\",\n  \"dsaPattern\": \"binarySearch\",\n  \"tags\": [\"search\", \"array\"],\n  \"testCases\": [\n    {\n      \"label\": \"Primary input\",\n      \"input\": {\n        \"raw\": \"array: [2,5,8,12,16,23,38] target: 23\"\n      }\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/codes",
          "host": ["{{baseUrl}}"],
          "path": ["api", "codes"]
        }
      }
    },
    {
      "name": "Execute Code",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"code\": \"function binarySearch(arr, target) { let left = 0; let right = arr.length - 1; while (left <= right) { const mid = left + Math.floor((right - left) / 2); if (arr[mid] === target) return mid; if (arr[mid] < target) left = mid + 1; else right = mid - 1; } return -1; }\",\n  \"language\": \"javascript\",\n  \"inputOverride\": \"array: [2,5,8,12,16,23,38] target: 23\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/execute",
          "host": ["{{baseUrl}}"],
          "path": ["api", "execute"]
        }
      }
    },
    {
